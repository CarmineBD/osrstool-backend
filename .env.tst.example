# Railway TST backend template.
# Stable frontend URL expected for this environment:
# https://osrstool-frontend-tst.vercel.app

NODE_ENV=production
PORT=3000

DATABASE_URL=postgres://USER:PASS@HOST:5432/DBNAME
REDIS_URL=redis://default:password@host:6379

HEALTH_CHECK_TIMEOUT_MS=1000
RATE_LIMIT_TTL_SECONDS=60
RATE_LIMIT_LIMIT=60

SCHEDULED_JOBS_ENABLED=true
ITEM_VOLUMES_INIT_ENABLED=true
VARIANT_HISTORY_PRUNE_ENABLED=false
VARIANT_HISTORY_RAW_RETENTION_HOURS=72
VARIANT_HISTORY_15M_RETENTION_DAYS=90
PRICE_CHANGE_WINDOW_SECONDS=120

CORS_ORIGINS=https://osrstool-frontend-tst.vercel.app

SWAGGER_ENABLED=false
CDN_BASE=
OSRS_WIKI_USER_AGENT=
APP_VERSION=
GIT_COMMIT=
BUILD_DATE=

SUPABASE_PROJECT_URL=https://YOUR_PROJECT_ID.supabase.co
SUPABASE_JWT_AUD=authenticated
