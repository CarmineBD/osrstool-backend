# Generic backend template.
# Copy to `.env` and adjust values for the environment you want to run.
# See also:
# - `.env.local.example`
# - `.env.tst.example`
# - `.env.production.example`

NODE_ENV=development
PORT=3000

# Use DATABASE_URL when you want a single connection string.
# If DATABASE_URL is set, the DB_* variables are ignored by TypeORM.
DATABASE_URL=postgres://USER:PASS@HOST:5432/DBNAME

# Redis is required for prices, profits, distributed locks and live caches.
REDIS_URL=redis://localhost:6379

# Optional split DB settings when DATABASE_URL is not used.
DB_HOST=localhost
DB_PORT=5432
DB_USER=osrs
DB_PASS=osrs
DB_NAME=osrs

HEALTH_CHECK_TIMEOUT_MS=1000
RATE_LIMIT_TTL_SECONDS=60
RATE_LIMIT_LIMIT=60

# Cron controls.
# Keep this `false` in local if your local backend points to shared remote DB/Redis.
SCHEDULED_JOBS_ENABLED=false

# Prices refresh behaviour.
PRICE_CHANGE_WINDOW_SECONDS=120

# Item-volume jobs.
ITEM_VOLUMES_INIT_ENABLED=false

# Variant-history retention and pruning.
VARIANT_HISTORY_PRUNE_ENABLED=false
VARIANT_HISTORY_RAW_RETENTION_HOURS=72
VARIANT_HISTORY_15M_RETENTION_DAYS=90

# Comma-separated allowlist for browser origins.
# Example: http://localhost:5173,https://osrstool-frontend-tst.vercel.app
CORS_ORIGINS=http://localhost:5173

# Optional runtime metadata.
SWAGGER_ENABLED=
CDN_BASE=
OSRS_WIKI_USER_AGENT=
APP_VERSION=
GIT_COMMIT=
BUILD_DATE=

# Supabase JWT validation for protected endpoints.
SUPABASE_PROJECT_URL=
SUPABASE_JWT_AUD=authenticated
