# Local backend template.
# Safe default when local points to a shared remote DB/Redis: jobs disabled.

NODE_ENV=development
PORT=3000

# Choose one approach:
# 1) single connection string
DATABASE_URL=postgres://USER:PASS@HOST:5432/DBNAME
# 2) or DB_* variables if DATABASE_URL is empty
# DB_HOST=localhost
# DB_PORT=5432
# DB_USER=osrs
# DB_PASS=osrs
# DB_NAME=osrs

REDIS_URL=redis://localhost:6379

HEALTH_CHECK_TIMEOUT_MS=1000
RATE_LIMIT_TTL_SECONDS=60
RATE_LIMIT_LIMIT=60

SCHEDULED_JOBS_ENABLED=false
ITEM_VOLUMES_INIT_ENABLED=false
VARIANT_HISTORY_PRUNE_ENABLED=false
VARIANT_HISTORY_RAW_RETENTION_HOURS=72
VARIANT_HISTORY_15M_RETENTION_DAYS=90
PRICE_CHANGE_WINDOW_SECONDS=120

CORS_ORIGINS=http://localhost:5173

SWAGGER_ENABLED=true
CDN_BASE=
OSRS_WIKI_USER_AGENT=
APP_VERSION=
GIT_COMMIT=
BUILD_DATE=

SUPABASE_PROJECT_URL=https://YOUR_PROJECT_ID.supabase.co
SUPABASE_JWT_AUD=authenticated
